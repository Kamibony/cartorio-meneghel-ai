{
  "hosting": {
    "public": "frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/extract_document_data",
        "function": "extract_document_data"
      },
      {
        "source": "/api/submit_audit_event",
        "function": "submit_audit_event"
      },
      {
        "source": "/api/api_status",
        "function": "api_status"
      },
      {
        "source": "/api/validate_document_text",
        "function": "validate_document_text"
      },
      {
        "source": "/api/log_audit_event",
        "function": "log_audit_event"
      },
      {
        "source": "/api/correct_document_text",
        "function": "correct_document_text"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "venv",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "runtime": "python311"
    }
  ]
}
